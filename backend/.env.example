# URL de conexão com o PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/everestfrags

# Chave secreta para assinar os JWTs (gere uma chave forte em produção)
SECRET_KEY=troque-essa-chave-por-uma-muito-segura

# Algoritmo de assinatura do JWT
ALGORITHM=HS256

# Tempo de expiração do token em minutos (43200 = 30 dias — token fica salvo
# no localStorage do navegador, então isso funciona como "lembrar de mim";
# evita ter que refazer o login via Steam toda vez que o token expira)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Steam Web API — obter em: https://steamcommunity.com/dev/apikey
# Necessaria para buscar nickname e avatar apos o login com Steam
STEAM_API_KEY=sua-chave-steam-aqui

# URLs da aplicacao (necessarias para o redirect do Steam OpenID)
# Em dev: backend=8001, frontend=5173
BACKEND_URL=http://localhost:8001
FRONTEND_URL=http://localhost:5173
