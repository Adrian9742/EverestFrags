# URL de conexão com o PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/everestfrags

# Chave secreta para assinar os JWTs (gere uma chave forte em produção)
SECRET_KEY=troque-essa-chave-por-uma-muito-segura

# Algoritmo de assinatura do JWT
ALGORITHM=HS256

# Tempo de expiração do token em minutos (480 = 8 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=480
